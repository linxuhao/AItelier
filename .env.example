# AItelier environment variables — example
#
# Copy to `.env` and fill in your keys, then load them into your shell:
#   cp .env.example .env
#   source .env
#
# `.env` is gitignored; this `.env.example` is safe to commit (no secrets).
# Provider base URLs are configured in llm_providers.json — only the keys live here.

# The default pipeline runs entirely on DeepSeek — this is the only key you need.
export DEEPSEEK_API_KEY=""

# Optional: other providers are registered in llm_providers.json. Add a key here
# only if you point an agent_config at that provider.
# export MINIMAX_API_KEY=""

# Optional: web search backend.
# AItelier's web_search tool queries a SearXNG instance (JSON API). It is
# OPTIONAL — leave SEARXNG_URL unset and the pipeline runs fine without web
# search (agents fall back to model knowledge; web_fetch still works on any URL).
# To enable, point at your own SearXNG (recommended) or a public instance that
# exposes format=json:
# export SEARXNG_URL="http://localhost:8888"
# export SEARXNG_TIMEOUT="10"
