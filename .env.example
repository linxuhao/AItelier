# AItelier environment variables — example
#
# Copy to `.env` and fill in your keys, then load them into your shell:
#   cp .env.example .env
#   source .env
#
# `.env` is gitignored; this `.env.example` is safe to commit (no secrets).
# Provider base URLs are configured in llm_providers.json — only the keys live here.

# The default pipeline runs entirely on DeepSeek — this is the only key you need.
#
# DOCKER: do NOT put this key here. It is delivered as a Docker secret (a file)
# so test/build subprocesses that inherit the environment never receive it:
#   mkdir -p ~/.aitelier-secrets && chmod 700 ~/.aitelier-secrets
#   printf '%s' "sk-..." > ~/.aitelier-secrets/DEEPSEEK_API_KEY && chmod 600 "$_"
# ai_router reads /run/secrets/DEEPSEEK_API_KEY. For LOCAL (non-docker) runs,
# either set AITELIER_SECRETS_DIR=~/.aitelier-secrets or export the key below.
# export DEEPSEEK_API_KEY=""

# Optional: other providers are registered in llm_providers.json. Add a key here
# only if you point an agent_config at that provider.
# export MINIMAX_API_KEY=""

# Optional: model for skillflow "host"-delegated agents. The skill_converter
# pipeline (and any generated pipeline) declares its agents as model:"host" with
# the prompt embedded; AItelier maps that single token to one real model.
# Defaults to deepseek/deepseek-v4-flash. Override only to use a different model.
# export AITELIER_HOST_AGENT_MODEL="deepseek/deepseek-v4-flash"

# Optional: web search backend.
# AItelier's web_search tool queries a SearXNG instance (JSON API). It is
# OPTIONAL — leave SEARXNG_URL unset and the pipeline runs fine without web
# search (agents fall back to model knowledge; web_fetch still works on any URL).
# To enable, point at your own SearXNG (recommended) or a public instance that
# exposes format=json:
# export SEARXNG_URL="http://localhost:8888"
# export SEARXNG_TIMEOUT="10"

# ── Cloudflare Access write-gate (Docker deployment) ──
# When the app is fronted by Cloudflare Access, reads are protected at the edge
# (any logged-in user) and writes are restricted to an allowlist. Set the team
# domain + the Access application's AUD tag to enable JWT verification; leave
# them blank to disable the gate (local dev — all requests allowed).
# export AITELIER_CF_TEAM_DOMAIN="<team>.cloudflareaccess.com"
# export AITELIER_CF_AUD="<application-audience-aud-tag>"
# Comma-separated emails allowed to perform writes (create/modify projects).
# export AITELIER_WRITERS="you@example.com"
# Shared secret the host CLI sends to bypass the write-gate (it has no JWT).
# Generate with:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# export AITELIER_ADMIN_TOKEN="<random-secret>"
