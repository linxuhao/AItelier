# AItelier environment variables — example
#
# Copy to `.env` and fill in your keys, then load them into your shell:
#   cp .env.example .env
#   source .env
#
# `.env` is gitignored; this `.env.example` is safe to commit (no secrets).
# Provider base URLs are configured in llm_providers.json — only the keys live here.

export DEEPSEEK_API_KEY=""
export MINIMAX_API_KEY=""
