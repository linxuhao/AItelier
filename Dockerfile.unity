# Dockerfile.unity — the `unity-builder` sidecar.
#
# A SEPARATE image from the main aitelier backend (which stays python:slim).
# It exists only to give C#/Unity projects a license-free *semantic* compile
# check: it wraps the editor's bundled Roslyn `csc` + Unity reference assemblies
# behind a tiny HTTP service (docker/unity/unity_compile.py, POST /compile).
#
# Why a sidecar and not the app's base image: the editor image is ~5GB and pins
# a Unity version; baking it into the main image would bloat every deploy and
# every Python project. C# projects reach this service over the compose network;
# Python projects never touch it. See docker-compose.yml `unity-builder`.
#
# Unity version = latest LTS (6000.0.x). `-base` module = editor + managed
# reference DLLs, no platform player build support (smallest variant; enough to
# compile-check scripts). Bump the tag to track a newer LTS patch.
FROM unityci/editor:ubuntu-6000.0.76f1-base-3.2.2

# Online Personal activation counts each distinct MACHINE against the account's
# small activation-seat limit. A container gets a fresh identity on every create,
# so without pinning, every `compose up --force-recreate` would burn another seat
# and eventually exhaust the account. The base image bakes a FIXED /etc/machine-id;
# hostname + MAC are pinned in docker-compose.yml. Together they keep the builder
# looking like ONE machine across restarts/recreates, so it re-uses the same seat.

COPY docker/unity/unity_compile.py /srv/unity_compile.py
COPY docker/unity/entrypoint.sh /srv/entrypoint.sh
RUN chmod +x /srv/entrypoint.sh

ENV PORT=8080
EXPOSE 8080

# The /compile route needs no license, but /playtest runs the editor (which does).
# The entrypoint does optional online Personal activation (UNITY_EMAIL/PASSWORD
# secrets), then starts the server — so compile keeps working with no license, and
# play-test lights up when activation succeeds. Bump the FROM tag AND
# EDITOR_VERSION in unity_compile.py together when tracking a newer LTS patch.
ENTRYPOINT ["/srv/entrypoint.sh"]
